--- import MainLayout from '../../layouts/MainLayout.astro'; const {slug}=Astro.params; const base=Astro.url.origin; let post=null,related=[]; try{post=await (await fetch(base+`/api/posts/${slug}`)).json()}catch{}; try{related=await (await fetch(base+'/api/posts')).json()}catch{} ---
<MainLayout title={post?.title || 'Article'}><div class='grid' style='grid-template-columns:2fr 1fr'><article class='card' style='padding:1rem'><h1>{post?.title}</h1><p>{post?.content}</p></article><aside class='card' style='padding:1rem;position:sticky;top:1rem'><h3>Suggested</h3>{related.slice(0,5).map(r=><p><a href={`/news/${r.slug}`}>{r.title}</a></p>)}</aside></div></MainLayout>
