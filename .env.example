# =============================================================================
# Yeh Mera India — News API Configuration
# =============================================================================
# Copy this file to .env and fill in your API keys to enable live news fetching.
# Without keys, the app will gracefully fall back to built-in demo data.
#
# FREE tier limits:
#   - NewsAPI.org: 100 requests/day
#   - GNews:       100 requests/day
# =============================================================================

# --- NewsAPI.org (Primary Provider) ---
# Get your free API key at: https://newsapi.org/register
# Free tier: 100 requests/day, no credit card required
VITE_NEWS_API_KEY=your_newsapi_key_here

# --- GNews (Secondary Provider) ---
# Get your free API key at: https://gnews.io/
# Free tier: 100 requests/day, no credit card required
VITE_GNEWS_API_KEY=your_gnews_key_here

# --- Live API Toggle ---
# Set to 'true' to enable fetching from NewsAPI.org and GNews.
# When 'false', the app uses RSS feeds (CORS-free) + demo data fallback.
VITE_USE_LIVE_API=false
