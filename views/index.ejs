<!doctype html><html><head><title><%= title %></title><link rel='stylesheet' href='/css/global.css'></head><body><%- include('partials/header') %><div class='container'><img src='/images/hero.svg' style='width:100%'><h3>Trending</h3><div><% categories.forEach(c=>{ %><a href='/category/<%= c %>'><%= c %></a> <% }) %></div><div class='grid'><% articles.forEach(a=>{ %><div class='card'><img src='<%= a.image %>' style='width:100%'><h4><a href='/news/<%= a.slug %>'><%= a.title %></a></h4><p><%= a.summary %></p></div><% }) %></div></div><%- include('partials/footer') %></body></html>
