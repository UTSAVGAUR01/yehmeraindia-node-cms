<!doctype html><html><head><title><%= article.title %></title><link rel='stylesheet' href='/css/global.css'></head><body><%- include('partials/header') %><div class='container'><h1><%= article.title %></h1><img src='<%= article.image %>' style='width:100%'><p><%= article.content %></p><h3>More Like This</h3><% articles.forEach(a=>{if(a.slug!==article.slug){ %><p><a href='/news/<%= a.slug %>'><%= a.title %></a></p><% }}) %></div><%- include('partials/footer') %></body></html>
