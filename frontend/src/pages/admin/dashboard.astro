--- import AdminLayout from '../../layouts/AdminLayout.astro'; const base=Astro.url.origin; let d={}; try{d=await (await fetch(base+'/api/admin/dashboard')).json();}catch{} ---
<AdminLayout title='Dashboard'><h1>Dashboard</h1><div class='stat-grid'>{['total_posts','published','pending','ai_generated','trending','users'].map(k=><div class='card'><h3>{k}</h3><p>{d[k] ?? '-'}</p></div>)}</div><div style='margin-top:1rem;display:flex;gap:1rem'><button class='btn'>AI Auto-Publish: {import.meta.env.PUBLIC_AI_AUTO_PUBLISH || 'off'}</button><button class='btn'>Retention Hours: {import.meta.env.PUBLIC_RETENTION_HOURS || '48'}</button></div></AdminLayout>
